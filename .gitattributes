# Git LFS tracking for binary files (required for HuggingFace Spaces)
# NOTE: small images kept as regular git objects (under 10MB)
# Only track very large files with LFS if needed
*.pkl filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
